{
  "expo": {
    "name": "Ctrl-Custo",
    "slug": "ctrl-custo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "ctrl-custo",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#14532D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hebert.ctrlcusto"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#14532D"
      },
      "package": "com.hebert.ctrlcusto"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Ctrl-Custo to use Face ID for authentication."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
