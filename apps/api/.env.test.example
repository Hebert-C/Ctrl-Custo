# Banco de dados exclusivo para testes — NUNCA aponte para produção
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ctrl_custo_test

# Segredos JWT para testes (valores fictícios, não usar em produção)
JWT_SECRET=test-jwt-secret-must-be-at-least-32-characters-long!!
JWT_REFRESH_SECRET=test-jwt-refresh-secret-must-be-at-least-32-chars!!

NODE_ENV=test
ALLOWED_ORIGINS=http://localhost

# SMTP — vazio: e-mails são mockados nos testes, não precisam de SMTP real
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@test.com
APP_URL=http://localhost:5173
