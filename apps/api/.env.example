# PostgreSQL connection string
DATABASE_URL=postgresql://ctrl_custo_user:password@localhost:5432/ctrl_custo

# JWT secrets — gere valores aleatórios com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque-por-um-segredo-aleatorio-de-256-bits
JWT_REFRESH_SECRET=troque-por-outro-segredo-aleatorio-de-256-bits

# Porta do servidor
PORT=3000

# Origens permitidas no CORS (separe múltiplas com vírgula, sem espaço)
ALLOWED_ORIGINS=http://localhost:5173,https://seu-dominio.com

# Ambiente (development | production)
NODE_ENV=development
